# nexus-booking environment variables
# Copy to .env and fill in the blanks

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nexus:nexuspassword@localhost:5432/nexusbooking

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256

# ── Service ───────────────────────────────────────────────────────────────────
PORT=8002
DEBUG=false

# ── Email (aiosmtplib) ────────────────────────────────────────────────────────
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
FROM_NAME=NexusConsult Booking
FROM_EMAIL=noreply@nexusconsult.dev
ADMIN_EMAIL=admin@nexusconsult.dev

# ── CORS ──────────────────────────────────────────────────────────────────────
# JSON array of allowed origins
CORS_ORIGINS=["http://localhost:5000","https://nexusconsult.dev"]

# ── Portfolio gateway ─────────────────────────────────────────────────────────
PORTFOLIO_URL=http://localhost:5000
